@inherits LayoutComponentBase
@using EcoMeal.Site.Services
@inject AuthService AuthService
@inject NavigationManager Navigation
@inject SearchState SearchState

<div class="page @ThemeClass">
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark border-bottom shadow-sm sticky-top py-3 @ThemeClass">
            <div class="container-fluid px-4">
                <div class="d-flex align-items-center justify-content-between gap-3 w-100">
                    <div class="d-flex align-items-center gap-3 flex-fill">
                        <a class="navbar-brand fw-bold mb-0 d-flex align-items-center" href="/">
                            <span class="brand-emoji">🍃</span>
                            <span class="brand-eco">Eco</span><span class="brand-meal">Meal</span>
                        </a>

                        <div class="flex-fill d-none d-md-flex">
                            <div class="input-group input-group-sm w-100 search-input-group">
                                <span class="input-group-text border-0">🔍</span>
                                <input class="form-control form-control-sm search-control" type="search" placeholder="Caută business..." @bind="SearchState.Query" @bind:event="oninput" aria-label="Căutare business" />
                            </div>
                        </div>
                    </div>

                    <div class="d-flex align-items-center gap-2">
                        <button class="btn btn-sm btn-outline-light theme-toggle-btn" @onclick="ToggleTheme" title="Comută tema">
                            <span class="me-1">@((isDarkTheme) ? "☀️" : "🌙")</span>
                        </button>
                        @if (AuthService.IsAuthenticated)
                        {
                            <button class="btn btn-sm btn-outline-light" @onclick="HandleLogout">Logout</button>
                        }
                        else
                        {
                            <a class="btn btn-sm btn-light" href="/login">Login</a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main class="container py-4">
        <article class="content">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool isDarkTheme = false;

    public Models.Auth.UserMeResponse? User { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await AuthService.LoadTokenAsync();
            StateHasChanged();
        }
    }

    private string ThemeClass => isDarkTheme ? "theme-dark" : "theme-light";

    private void ToggleTheme()
    {
        isDarkTheme = !isDarkTheme;
    }

    private async Task HandleLogout()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/", forceLoad: true);
    }
}
