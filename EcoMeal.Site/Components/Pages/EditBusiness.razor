@page "/business/{Id:int}/edit"
@using EcoMeal.Site.Models
@using EcoMeal.Site.Services
@using Microsoft.AspNetCore.Components.Forms

@if (BusinessModel is null)
{
    <p class="text-center mt-5">Loading...</p>
    return;
}

<div class="form-page-layout">
    <div class="form-container">
        <h2 class="form-title mb-4">Editare Business</h2>

        <EditForm Model="BusinessModel" OnValidSubmit="HandleUpdate">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="mb-3">
                <label class="form-label text-muted">Nume</label>
                <InputText class="form-input" @bind-Value="BusinessModel.Name" />
                <ValidationMessage For="() => BusinessModel.Name" />
            </div>

            <div class="mb-3">
                <label class="form-label text-muted">Adresă</label>
                <InputText class="form-input" @bind-Value="BusinessModel.Address" />
                <ValidationMessage For="() => BusinessModel.Address" />
            </div>

            <div class="mb-3">
                <label class="form-label text-muted">Descriere</label>
                <InputTextArea class="form-input" @bind-Value="BusinessModel.Description" rows="4" />
            </div>

            <div class="mb-3">
                <label class="form-label text-muted">Contact</label>
                <InputText class="form-input" @bind-Value="BusinessModel.Contact" />
                <ValidationMessage For="() => BusinessModel.Contact" />
            </div>

            <div class="mb-3">
                <label class="form-label text-muted">Tip Business</label>
                <InputSelect class="form-input" @bind-Value="BusinessModel.BusinessTypeId">
                    <option value="0" disabled>Alege tipul...</option>
                    @foreach (var type in BusinessTypes)
                    {
                        <option value="@type.Id">@type.Name</option>
                    }
                </InputSelect>
                <ValidationMessage For="() => BusinessModel.BusinessTypeId" />
            </div>

            <div class="mb-3">
                <label class="form-label text-muted">Imagine Business</label>
                <InputFile OnChange="HandleFileSelection" class="form-control" />
                @if (!string.IsNullOrWhiteSpace(imagePreview))
                {
                    <img src="@imagePreview" class="mt-2" style="max-width: 200px;" />
                }
            </div>

            <button type="submit" class="btn-action mt-3">Actualizează</button>
        </EditForm>
    </div>
</div>

@code {
    [Parameter] public int Id { get; set; }
    [Inject] public required BusinessService BusinessService { get; set; }
    [Inject] public required NavigationManager NavigationManager { get; set; }
    [Inject] public required IJSRuntime JS { get; set; }

    private BusinessUpdateModel? BusinessModel { get; set; }
    private List<BusinessTypeModel> BusinessTypes { get; set; } = new();
    private IBrowserFile? selectedFile;
    private string? imagePreview;

    protected override async Task OnInitializedAsync()
    {
        BusinessTypes = await BusinessService.GetBusinessTypesAsync();
        var business = await BusinessService.GetOneById(Id);
        if (business is not null)
        {
            BusinessModel = new BusinessUpdateModel
            {
                Name = business.Name,
                Address = business.Address,
                Description = business.Description,
                Contact = business.Contact,
                BusinessTypeId = business.BusinessTypeId
            };

            imagePreview = BusinessService.BuildBusinessImageUrl(business.ImagePath);
        }
    }

    private async Task HandleFileSelection(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
        if (selectedFile is null)
        {
            return;
        }

        var maxAllowedSize = 1024 * 1024 * 2;

        try
        {
            var resizedImage = await selectedFile.RequestImageFileAsync("image/png", 400, 400);

            using var memoryStream = new MemoryStream();
            await resizedImage.OpenReadStream(maxAllowedSize).CopyToAsync(memoryStream);
            var buffer = memoryStream.ToArray();
            imagePreview = $"data:image/png;base64,{Convert.ToBase64String(buffer)}";
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Eroare la generarea preview-ului: {ex.Message}");
            imagePreview = null;
        }
    }

    private async Task HandleUpdate()
    {
        if (BusinessModel is null)
        {
            return;
        }

        var content = new MultipartFormDataContent();

        content.Add(new StringContent(BusinessModel.Name), "Name");
        content.Add(new StringContent(BusinessModel.Address), "Address");
        content.Add(new StringContent(BusinessModel.Contact), "Contact");
        content.Add(new StringContent(BusinessModel.Description ?? string.Empty), "Description");
        content.Add(new StringContent(BusinessModel.BusinessTypeId.ToString()), "BusinessTypeId");

        if (selectedFile is not null)
        {
            var fileContent = new StreamContent(selectedFile.OpenReadStream(maxAllowedSize: 1024 * 1024 * 2));
            fileContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(selectedFile.ContentType);
            content.Add(fileContent, "ImageFile", selectedFile.Name);
        }

        var result = await BusinessService.UpdateBusinessAsync(Id, content);
        if (result.Success)
        {
            NavigationManager.NavigateTo($"/business/{Id}");
        }
        else
        {
            var message = string.IsNullOrWhiteSpace(result.ErrorMessage)
                ? "A apărut o eroare la actualizarea business-ului!"
                : $"A apărut o eroare la actualizarea business-ului: {result.ErrorMessage}";

            await JS.InvokeVoidAsync("alert", message);
        }
    }
}
