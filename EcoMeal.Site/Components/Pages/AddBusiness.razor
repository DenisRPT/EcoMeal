@page "/business/add"
@using EcoMeal.Site.Models
@using EcoMeal.Site.Services

<div class="form-page-layout">
    <div class="form-container">
        <h2 class="form-title">Adaugă Business</h2>

        <EditForm Model="BusinessModel" OnValidSubmit="HandleCreate">
            <DataAnnotationsValidator />

            <div class="mb-3">
                <label class="form-label">Nume</label>
                <InputText class="form-input" @bind-Value="BusinessModel.Name" />
            </div>

            <div class="mb-3">
                <label class="form-label">Adresă</label>
                <InputText class="form-input" @bind-Value="BusinessModel.Address" />
            </div>

            <div class="mb-3">
                <label class="form-label">Descriere</label>
                <InputTextArea class="form-input" @bind-Value="BusinessModel.Description" rows="4" />
            </div>

            <div class="mb-3">
                <label class="form-label">Contact</label>
                <InputText class="form-input" @bind-Value="BusinessModel.Contact" />
            </div>

            <div class="mb-3">
                <label class="form-label">Tip Business</label>
                <InputSelect class="form-input" @bind-Value="BusinessModel.BusinessTypeId">
                    <option value="0" disabled>Alege tipul...</option>
                    @foreach (var type in BusinessTypes)
                    {
                        <option value="@type.Id">@type.Name</option>
                    }
                </InputSelect>
            </div>

            <button type="submit" class="btn-action">Salvează</button>
        </EditForm>
    </div>
</div>

@code {
    [Inject] public required BusinessService BusinessService { get; set; }
    [Inject] public required NavigationManager NavigationManager { get; set; }

    private BusinessAddModel BusinessModel { get; set; } = new BusinessAddModel();
    private List<BusinessTypeModel> BusinessTypes { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        BusinessTypes = await BusinessService.GetBusinessTypesAsync();
    }

    private async Task HandleCreate()
    {
        await BusinessService.CreateBusinessAsync(BusinessModel);
        NavigationManager.NavigateTo("/");
    }
}
