@page "/business/add"
@using EcoMeal.Site.Models
@using EcoMeal.Site.Services

<div class="form-page-layout">
    <div class="form-container">
        <h2 class="form-title">Adaugă Business</h2>

        <EditForm Model="BusinessModel" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="mb-3">
                <label class="form-label">Nume</label>
                <InputText class="form-input" @bind-Value="BusinessModel.Name" />
            </div>

            <div class="mb-3">
                <label class="form-label">Adresă</label>
                <InputText class="form-input" @bind-Value="BusinessModel.Address" />
            </div>

            <div class="mb-3">
                <label class="form-label">Descriere</label>
                <InputTextArea class="form-input" @bind-Value="BusinessModel.Description" rows="4" />
            </div>

            <div class="mb-3">
                <label class="form-label">Contact</label>
                <InputText class="form-input" @bind-Value="BusinessModel.Contact" />
            </div>

            <div class="mb-3">
                <label class="form-label">Tip Business</label>
                <InputSelect class="form-input" @bind-Value="BusinessModel.BusinessTypeId">
                    <option value="0" disabled>Alege tipul...</option>
                    @foreach (var type in BusinessTypes)
                    {
                        <option value="@type.Id">@type.Name</option>
                    }
                </InputSelect>
            </div>
            <div class="mb-3">
                <label class="form-label">Imagine Business</label>
                <InputFile OnChange="HandleFileSelection" class="form-control" />
                @if (imagePreview != null)
                {
                    <img src="@imagePreview" class="mt-2" style="max-width: 200px;" />
                }
            </div>

            <button type="submit" class="btn-action">Salvează</button>
        </EditForm>
    </div>
</div>

@code {
    [Inject] public required BusinessService BusinessService { get; set; }
    [Inject] public required NavigationManager NavigationManager { get; set; }
    [Inject] public required IJSRuntime JS { get; set; }

    private BusinessAddModel BusinessModel { get; set; } = new BusinessAddModel();
    private List<BusinessTypeModel> BusinessTypes { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        BusinessTypes = await BusinessService.GetBusinessTypesAsync();
    }

    @* private async Task HandleCreate()
    {
        await BusinessService.CreateBusinessAsync(BusinessModel);
        NavigationManager.NavigateTo("/");
    } *@

    private IBrowserFile? selectedFile;
    private string? imagePreview;
    private async Task HandleFileSelection(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
        if (selectedFile != null)
        {
            var maxAllowedSize = 1024 * 1024 * 2; 
            
            try 
            {
                var resizedImage = await selectedFile.RequestImageFileAsync("image/png", 400, 400);
                
                using (var memoryStream = new MemoryStream())
                {
                    await resizedImage.OpenReadStream(maxAllowedSize).CopyToAsync(memoryStream);
                    var buffer = memoryStream.ToArray();
                    imagePreview = $"data:image/png;base64,{Convert.ToBase64String(buffer)}";
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Eroare la generarea preview-ului: {ex.Message}");
                imagePreview = null;
            }
        }
    }

    private async Task HandleSubmit()
    {
        var content = new MultipartFormDataContent();

        content.Add(new StringContent(BusinessModel.Name), "Name");
        content.Add(new StringContent(BusinessModel.Address), "Address");
        content.Add(new StringContent(BusinessModel.Contact), "Contact");
        content.Add(new StringContent(BusinessModel.Description ?? string.Empty), "Description");
        content.Add(new StringContent(BusinessModel.BusinessTypeId.ToString()), "BusinessTypeId");

        if (selectedFile != null)
        {
            var fileContent = new StreamContent(selectedFile.OpenReadStream(maxAllowedSize: 1024 * 1024 * 2));
            fileContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(selectedFile.ContentType);
            content.Add(fileContent, "ImageFile", selectedFile.Name);
        }

        var result = await BusinessService.CreateBusinessAsync(content);

        if (result.Success)
        {
            NavigationManager.NavigateTo("/");
        }
        else
        {
            var message = string.IsNullOrWhiteSpace(result.ErrorMessage)
                ? "A apărut o eroare la salvarea business-ului!"
                : $"A apărut o eroare la salvarea business-ului: {result.ErrorMessage}";

            await JS.InvokeVoidAsync("alert", message);
        }
    } 

}
