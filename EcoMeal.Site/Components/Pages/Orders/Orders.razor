@page "/orders"

<PageTitle>Comenzile mele</PageTitle>

<div class="orders-page-container container mt-4">
    <h2 class="page-title mb-4">Comenzile Mele</h2>
    
    @if (MyOrders is null)
    {
        <p class="text-center mt-5 text-muted">Loading...</p>
    }
    else if(!MyOrders.Any())
    {
        <div class="empty-state mt-4">
            <p>Nu ai nicio comandă încă.</p>
        </div>
    }
    else
    {
        <div class="orders-list">
            @foreach(var order in MyOrders)
            {
                <div class="order-card">
                    <div class="order-info">
                        <h5 class="order-title">@order.PackageName</h5>
                        <p class="order-business">
                            <span class="me-1">🏢</span> @order.BusinessName
                        </p>
                        <p class="order-date">
                            <span class="me-1">🕒</span> @order.Date.ToString("dd.MM.yyyy HH:mm")
                        </p>
                    </div>
                    <div class="order-meta">
                        <div class="order-price">@order.Price.ToString("0.00") lei</div>
                        <span class="badge rounded-pill order-badge @GetBadgeClass(order.Status)">
                            @order.Status
                        </span>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private string GetBadgeClass(string status)
    {
        return status switch
        {
            "Rezervat" => "bg-info text-dark",
            "Plasata" => "bg-primary text-white",
            "Preluata" => "bg-warning text-dark",
            "Livrat" => "bg-success text-white",
            "Anulata" => "bg-danger text-white",
            "Expirata" => "bg-secondary text-white",
            _ => "bg-light text-dark",
        };
    }
}

