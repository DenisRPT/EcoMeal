@page "/business/{Id:int}"
@using Microsoft.AspNetCore.Components.Authorization
@using global::EcoMeal.Site.Models
@using global::EcoMeal.Site.Services

@if (Business is null)
{
    <p>Loading...</p>
}
else
{
    <div class="business-page">
        <section class="business-hero">
        <div class="hero-content">
            <span class="hero-badge">@Business.BusinessTypeName</span>
            <h1>@Business.Name</h1>
            <p>@Business.Description</p>
        </div>
        <div class="hero-details">
            <div class="info-card">
                <span class="info-label">Contact</span>
                <strong>@Business.Contact</strong>
            </div>
            <div class="info-card">
                <span class="info-label">Adresă</span>
                <strong>@Business.Address</strong>
            </div>
            <AuthorizeView Roles="Admin">
            <div class="info-card align-self-start">
                <button class="btn btn-outline-secondary btn-md" @onclick="NavigateToEditBusiness">Edit</button>
            </div>
            </AuthorizeView>
        </div>
    </section>

    <section class="packages-section">
        @if (!string.IsNullOrEmpty(FeedbackMessage))
        {
            <div class="alert @FeedbackClass" role="alert">@FeedbackMessage</div>
        }
        <div class="section-header">
            <div>
                <h2>Pachete disponibile</h2>
                <p>Explorează ofertele acestui business.</p>
            </div>
            <AuthorizeView Roles="Admin">
            <button type="button" class="btn btn-primary" @onclick="NavigateToAddPackage">
                + Adaugă pachet
            </button>
            </AuthorizeView>
        </div>

        @if (Business.Packages is { Count: > 0 })
        {
            <div class="packages-grid">
                @foreach (var package in Business.Packages)
                {
                    <div class="package-card">
                        <div class="package-card-body">
                            <div class="package-top">
                                <h5>@package.Name</h5>
                                <span class="package-price">@package.Price.ToString("0.00") lei</span>
                            </div>
                            <p class="package-description">@package.Description</p>
                            <div class="package-meta">
                                <div>
                                    <span class="meta-label">Pickup</span>
                                    <strong>@package.PickupStart.ToString("dd/MM/yyyy HH:mm")</strong>
                                </div>
                                <div>
                                    <span class="meta-label">Până</span>
                                    <strong>@package.PickupEnd.ToString("dd/MM/yyyy HH:mm")</strong>
                                </div>
                            </div>
                            <AuthorizeView>
                                <Authorized>
                                    <div class="package-actions">
                                        <button class="btn btn-primary btn-sm" @onclick="() => ReservePackage(package.Id)">Rezervă</button>
                                    </div>
                                </Authorized>
                            </AuthorizeView>
                            <AuthorizeView Roles="Admin">
                                <div class="package-actions">
                                    <button class="btn btn-outline-secondary btn-sm" @onclick="() => NavigateToEditPackage(package.Id)">Update</button>
                                    <button class="btn btn-outline-danger btn-sm ms-2" @onclick="() => DeletePackage(package.Id)">Delete</button>
                                </div>
                            </AuthorizeView>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="empty-state">
                <p>Nu există pachete disponibile pentru acest business.</p>
            </div>
        }
    </section>
</div>
}

@code {
        [Parameter]
        public int Id { get; set; }

        [Inject]
        public required BusinessService businessService { get; set; }
        [Inject]
        public required OrderService orderService { get; set; }
        [Inject]
        public required NavigationManager NavigationManager { get; set; } 

        private BusinessDetailsModel? Business;
        private string? FeedbackMessage;
        private string? FeedbackClass;

        protected override async Task OnInitializedAsync()
        {
            Business = await businessService.GetOneById(Id);
        }

        public void NavigateToAddPackage()
        {
            NavigationManager.NavigateTo($"/business/{Id}/addPackage");
        }

        public void NavigateToEditPackage(int packageId)
        {
            NavigationManager.NavigateTo($"/business/{Id}/package/{packageId}/edit");
        }

        public async Task DeletePackage(int packageId)
        {
            await businessService.DeletePackageAsync(Id, packageId);
            Business = await businessService.GetOneById(Id);
        }

        public async Task ReservePackage(int packageId)
        {
            try
            {
                var ok = await orderService.PlaceOrderAsync(packageId);
                if (ok)
                {
                    if (Business != null)
                    {
                        var pkg = Business.Packages.FirstOrDefault(p => p.Id == packageId);
                        if (pkg != null)
                        {
                            Business.Packages.Remove(pkg);
                        }
                    }
                    FeedbackMessage = "Pachet rezervat cu succes.";
                    FeedbackClass = "alert-success";
                }
                else
                {
                    FeedbackMessage = "Eroare la rezervare.";
                    FeedbackClass = "alert-danger";
                }
            }
            catch (Exception)
            {
                FeedbackMessage = "Eroare la rezervare.";
                FeedbackClass = "alert-danger";
            }

            StateHasChanged();
            await Task.Delay(3000);
            FeedbackMessage = null;
            FeedbackClass = null;
            StateHasChanged();
        }

        public void NavigateToEditBusiness()
        {
            NavigationManager.NavigateTo($"/business/{Id}/edit");
        }
}